<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="32dp"
        android:paddingBottom="40dp">

        <!-- Back button row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/backBtn"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="← Back"
                android:textColor="@color/colorPrimary"
                android:textSize="15sp" />

            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />

        </LinearLayout>

        <!-- Logo + App Name -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="28dp">

            <ImageView
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:src="@drawable/ic_nexuzy_logo"
                android:contentDescription="NexuzyAI Logo"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NexuzyAI"
                android:textSize="30sp"
                android:textStyle="bold"
                android:textColor="@color/colorPrimary"
                android:fontFamily="sans-serif-light" />

            <TextView
                android:id="@+id/versionText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Version 1.0.0"
                android:textSize="13sp"
                android:textColor="@color/colorHint"
                android:layout_marginTop="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Powered by Qwen3 · On-Device AI"
                android:textSize="12sp"
                android:textColor="@color/colorHint"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- Divider -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/colorBadgeBorder" android:layout_marginBottom="20dp" />

        <!-- Developer Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/colorSurface"
            app:cardCornerRadius="14dp"
            app:cardElevation="3dp"
            android:layout_marginBottom="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👨‍💻  Developer"
                    android:textSize="13sp"
                    android:textColor="@color/colorHint"
                    android:textAllCaps="true"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="David"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="?android:textColorPrimary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Managed by Nexuzy Lab"
                    android:textSize="13sp"
                    android:textColor="@color/colorHint"
                    android:layout_marginTop="2dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Contact Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/colorSurface"
            app:cardCornerRadius="14dp"
            app:cardElevation="3dp"
            android:layout_marginBottom="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📧  Support"
                    android:textSize="13sp"
                    android:textColor="@color/colorHint"
                    android:textAllCaps="true"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/emailNexuzy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="nexuzylab@gmail.com"
                    android:textSize="14sp"
                    android:textColor="@color/colorPrimary"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/emailDavid"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="davidk76011@gmail.com"
                    android:textSize="14sp"
                    android:textColor="@color/colorPrimary" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Privacy Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/colorSurface"
            app:cardCornerRadius="14dp"
            app:cardElevation="3dp"
            android:layout_marginBottom="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔒  Privacy"
                    android:textSize="13sp"
                    android:textColor="@color/colorHint"
                    android:textAllCaps="true"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="NexuzyAI runs entirely on your device. We do not collect, store, or transmit any personal data, conversations, location, or usage information to any server."
                    android:textSize="14sp"
                    android:textColor="?android:textColorPrimary"
                    android:lineSpacingExtra="3dp"
                    android:layout_marginBottom="10dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/privacyPolicyBtn"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Read Full Privacy Policy"
                    android:textColor="@color/colorPrimary"
                    app:strokeColor="@color/colorPrimary" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Open Source Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/colorSurface"
            app:cardCornerRadius="14dp"
            app:cardElevation="3dp"
            android:layout_marginBottom="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🐙  Open Source"
                    android:textSize="13sp"
                    android:textColor="@color/colorHint"
                    android:textAllCaps="true"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="NexuzyAI is free and open source under the MIT License. Contributions are welcome!"
                    android:textSize="14sp"
                    android:textColor="?android:textColorPrimary"
                    android:lineSpacingExtra="3dp"
                    android:layout_marginBottom="10dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/githubBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🐙  View on GitHub"
                    android:backgroundTint="@color/colorPrimary"
                    app:cornerRadius="8dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- License line -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="MIT License · © 2025 David / Nexuzy Lab"
            android:textSize="12sp"
            android:textColor="@color/colorHint"
            android:gravity="center"
            android:layout_marginTop="12dp" />

    </LinearLayout>
</ScrollView>
