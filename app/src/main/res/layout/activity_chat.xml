<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <!-- Top bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="58dp"
        android:background="@color/colorTopBar"
        android:elevation="6dp"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="4dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Logo icon -->
        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_nexuzy_logo"
            android:contentDescription="logo"
            android:layout_marginEnd="10dp" />

        <!-- Title + subtitle column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NexuzyAI"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@color/colorPrimary"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="by Nexuzy Lab"
                android:textSize="10sp"
                android:textColor="@color/colorHint" />

        </LinearLayout>

        <!-- Model badge -->
        <TextView
            android:id="@+id/modelBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Qwen3"
            android:textSize="11sp"
            android:textColor="@color/colorBadgeText"
            android:background="@drawable/badge_bg"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:layout_marginEnd="4dp" />

        <!-- About button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/aboutBtn"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="ℹ️"
            android:textSize="16sp"
            android:textColor="@color/colorPrimary" />

        <!-- Clear button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/clearBtn"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="↺"
            android:textSize="18sp"
            android:textColor="@color/colorPrimary" />

    </LinearLayout>

    <!-- AdMob Banner -->
    <LinearLayout
        android:id="@+id/adContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:background="@color/colorSurface"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Chat list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chatRecyclerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/adContainer"
        app:layout_constraintBottom_toTopOf="@id/typingIndicator"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Typing indicator -->
    <TextView
        android:id="@+id/typingIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="●●●  NexuzyAI is thinking…"
        android:textSize="12sp"
        android:textColor="@color/colorTyping"
        android:paddingStart="16dp"
        android:paddingBottom="2dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/inputCard"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Voice orb -->
    <View
        android:id="@+id/voiceOrb"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@drawable/voice_orb_bg"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/inputCard"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="4dp" />

    <!-- Input card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/inputCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/colorInputCard"
        app:cardCornerRadius="28dp"
        app:cardElevation="8dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="14dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="8dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/messageInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Ask NexuzyAI…"
                android:textColor="?android:textColorPrimary"
                android:textColorHint="@color/colorHint"
                android:textSize="15sp"
                android:background="@android:color/transparent"
                android:maxLines="4"
                android:inputType="textMultiLine|textCapSentences" />

            <!-- Voice btn -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/voiceBtn"
                style="@style/Widget.MaterialComponents.Button.Icon"
                android:layout_width="44dp"
                android:layout_height="44dp"
                app:icon="@android:drawable/ic_btn_speak_now"
                app:iconSize="22dp"
                app:iconTint="@color/colorPrimary"
                android:backgroundTint="@android:color/transparent"
                app:cornerRadius="22dp"
                android:contentDescription="Voice" />

            <!-- Send btn -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/sendBtn"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:text="➤"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:backgroundTint="@color/colorPrimary"
                app:cornerRadius="22dp"
                android:layout_marginStart="4dp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
