<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A1A">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="#111128"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="NexuzyAI"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#4FC3F7"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:id="@+id/modelBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Qwen 3B"
            android:textSize="11sp"
            android:textColor="#A0A0C0"
            android:background="@drawable/badge_bg"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp" />

    </LinearLayout>

    <!-- AdMob Banner at top below toolbar -->
    <LinearLayout
        android:id="@+id/adContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:background="#0D0D20"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Chat RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chatRecyclerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/adContainer"
        app:layout_constraintBottom_toTopOf="@id/typingIndicator"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Typing indicator -->
    <TextView
        android:id="@+id/typingIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="● NexuzyAI is thinking..."
        android:textSize="12sp"
        android:textColor="#4FC3F7"
        android:paddingStart="16dp"
        android:paddingBottom="4dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/inputCard"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Voice orb (pulse animation when listening) -->
    <View
        android:id="@+id/voiceOrb"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@drawable/voice_orb_bg"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/inputCard"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp" />

    <!-- Input Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/inputCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#1A1A2E"
        app:cardCornerRadius="28dp"
        app:cardElevation="8dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/messageInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Ask NexuzyAI..."
                android:textColor="#FFFFFF"
                android:textColorHint="#666688"
                android:textSize="15sp"
                android:background="@android:color/transparent"
                android:maxLines="3"
                android:inputType="textMultiLine|textCapSentences" />

            <!-- Voice button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/voiceBtn"
                style="@style/Widget.MaterialComponents.Button.Icon"
                android:layout_width="44dp"
                android:layout_height="44dp"
                app:icon="@android:drawable/ic_btn_speak_now"
                app:iconSize="22dp"
                app:iconTint="#4FC3F7"
                android:backgroundTint="#22334466"
                app:cornerRadius="22dp"
                android:contentDescription="Voice input" />

            <!-- Send button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/sendBtn"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:text="➤"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:backgroundTint="#1A73E8"
                app:cornerRadius="22dp"
                android:layout_marginStart="4dp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
