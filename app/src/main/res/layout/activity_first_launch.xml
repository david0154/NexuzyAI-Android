<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp"
        android:gravity="center_horizontal">

        <!-- Logo placeholder -->
        <ImageView
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="16dp"
            android:src="@mipmap/ic_launcher_round"
            android:contentDescription="NexuzyAI Logo" />

        <!-- Title -->
        <TextView
            android:id="@+id/tvFirstTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🤖 Welcome to NexuzyAI"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"
            android:layout_marginBottom="8dp" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/tvFirstSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your private on-device AI assistant."
            android:textSize="14sp"
            android:gravity="center"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginBottom="16dp" />

        <!-- Internet status badge -->
        <TextView
            android:id="@+id/tvInternetBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🟜 Internet: Checking…"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <!-- Status card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">
            <TextView
                android:id="@+id/tvFirstStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.4"
                android:textColor="?attr/colorOnSurface" />
        </androidx.cardview.widget.CardView>

        <!-- Model info card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">
            <TextView
                android:id="@+id/tvModelInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.4"
                android:textColor="?attr/colorOnSurfaceVariant" />
        </androidx.cardview.widget.CardView>

        <!-- Download progress -->
        <ProgressBar
            android:id="@+id/downloadProgressBar"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:max="100"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvDownloadProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginBottom="16dp"
            android:visibility="gone" />

        <!-- Download button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDownloadModel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⬇️ Download AI Model"
            android:textSize="15sp"
            android:layout_marginBottom="12dp"
            style="@style/Widget.Material3.Button" />

        <!-- Skip / Start Now button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSkipDownload"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="▶️ Start Now (Use Offline AI)"
            android:textSize="15sp"
            android:layout_marginBottom="24dp"
            style="@style/Widget.Material3.Button.OutlinedButton" />

    </LinearLayout>
</ScrollView>
