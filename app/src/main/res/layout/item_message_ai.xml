<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingStart="8dp"
    android:paddingEnd="8dp"
    android:paddingTop="4dp"
    android:paddingBottom="4dp"
    android:gravity="start">

    <TextView
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:text="&#x1F916;"
        android:textSize="20sp"
        android:gravity="center"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="4dp" />

    <!--
        bubbleCard: ID used by ChatAdapter for long-press copy.
        android:foreground ripple gives visual feedback on long-press.
    -->
    <androidx.cardview.widget.CardView
        android:id="@+id/bubbleCard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/colorAiBubble"
        app:cardCornerRadius="20dp"
        app:cardElevation="2dp"
        android:layout_marginEnd="64dp"
        android:foreground="?attr/selectableItemBackground"
        android:longClickable="true">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="10dp"
            android:paddingBottom="6dp">

            <!--
                textIsSelectable: lets user highlight specific words
                and use system Copy / Share / Translate etc.
            -->
            <TextView
                android:id="@+id/msgText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/colorAiText"
                android:textSize="15sp"
                android:lineSpacingExtra="2dp"
                android:textIsSelectable="true" />

            <TextView
                android:id="@+id/msgTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="@color/colorTimestamp"
                android:layout_marginTop="3dp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>
